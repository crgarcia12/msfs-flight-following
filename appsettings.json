{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Default": "Information",
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Message}{NewLine}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "outputTemplate": "{Timestamp:o} [{Level:u3}] ({SourceContext}) {Message}{NewLine}{Exception}",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ],
    "Properties": {
      "Application": "MSFSFlightFollowing"
    }
  },
  "Urls": "http://0.0.0.0:7777",
  "Features": {
    "AzureEventHub": {
      "Enabled": false,
      "Namespace": "crgar-eventhub.servicebus.windows.net",
      "Hub": "msfs"
    },
    "SimBridge": {
      "Enabled": true,
      "Url": "ws://localhost:8380/interfaces/v1/mcdu"
    },
    "Agents": {
      "Enabled": false
    },
    "Vatsim": {
      "Enabled": true,
      "PollIntervalSeconds": 20,
      "RangeBufferNm": 0
    },
    "Descent": {
      "Enabled": false,
      "TargetAltitudeFeet": 10000,
      "CooldownSeconds": 60
    },
    "Sim": {
      "WriteEnabled": true
    }
  }
}